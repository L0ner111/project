	$(MAKE) $(MAKESILENT) -f CMakeFiles/server.dir/build.make CMakeFiles/server.dir/src/weight_fusion.c.s
.PHONY : src/weight_fusion.c.s

test/test_unit_conversion.o: test/test_unit_conversion.cpp.o
.PHONY : test/test_unit_conversion.o

# target to build an object file
test/test_unit_conversion.cpp.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_unit_conversion.dir/build.make CMakeFiles/test_unit_conversion.dir/test/test_unit_conversion.cpp.o
.PHONY : test/test_unit_conversion.cpp.o

test/test_unit_conversion.i: test/test_unit_conversion.cpp.i
.PHONY : test/test_unit_conversion.i

# target to preprocess a source file
test/test_unit_conversion.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_unit_conversion.dir/build.make CMakeFiles/test_unit_conversion.dir/test/test_unit_conversion.cpp.i
.PHONY : test/test_unit_conversion.cpp.i

test/test_unit_conversion.s: test/test_unit_conversion.cpp.s
.PHONY : test/test_unit_conversion.s

# target to generate assembly for a file
test/test_unit_conversion.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_unit_conversion.dir/build.make CMakeFiles/test_unit_conversion.dir/test/test_unit_conversion.cpp.s
.PHONY : test/test_unit_conversion.cpp.s

